# App
APP_NAME=HabitFlow API
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL / Neon
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=your-db
POSTGRES_USER=your-user
POSTGRES_PASSWORD=your-password
POSTGRES_SSLMODE=require

# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DATABASE=habitflow_c21200065

# Redis
REDIS_URL=redis://default:password@host:port

# Object storage
OBJECT_STORAGE_BUCKET=your-bucket
OBJECT_STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
OBJECT_STORAGE_ACCESS_KEY=your-access-key
OBJECT_STORAGE_SECRET_KEY=your-secret-key
OBJECT_STORAGE_REGION=auto

# Auth
SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google login
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-render-service.onrender.com/c21200065/auth/google/callback

# AI / voice endpoint support
LLM_URL=http://127.0.0.1:9000
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-ai-key
LLM_MODEL=gpt-5.5

# Seed
SEED_ADMIN_EMAIL=admin@habitflow.com
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_DOCUMENT_ID=00000000

# HabitFlow backend environment example.
# Copy to backend/credentials/c21200065.env for local backend execution.
# Use only safe example values here; never commit real credentials.

# Obligatoria en Render/local: permite importar app.main desde backend/src.
PYTHONPATH=src

# Opcional: metadatos de runtime.
APP_NAME=HabitFlow API
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=

# Obligatorias: PostgreSQL / Neon.
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=your-db
POSTGRES_USER=your-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_SSLMODE=require

# Obligatorias actualmente: MongoDB se inicializa desde Settings.
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DATABASE=habitflow_c21200065

# Obligatoria actualmente: Redis se inicializa desde Settings.
REDIS_URL=redis://default:password@host:port

# Obligatorias si se usan storage/upload-url y storage/confirm.
OBJECT_STORAGE_PROVIDER=r2
OBJECT_STORAGE_BUCKET=your-bucket
OBJECT_STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
OBJECT_STORAGE_ACCESS_KEY=your-object-storage-access-key
OBJECT_STORAGE_SECRET_KEY=your-object-storage-secret-key
OBJECT_STORAGE_REGION=auto

# Obligatorias: firma y expiracion de tokens JWT.
SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# Obligatorias para Google Sign-In Android.
# GOOGLE_CLIENT_ID es alias compatible; mantenlo igual que GOOGLE_WEB_CLIENT_ID.
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Opcionales actualmente: no se usan para verificar ID tokens Android.
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-render-service.onrender.com/c21200065/auth/google/callback

# Opcionales: cliente LLM legado/configurable.
LLM_TYPE=local
LLM_PROVIDER=openai
LLM_URL=http://127.0.0.1:9000
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-5.5

# Opcionales: transcripcion server-side legacy. La app usa SpeechRecognizer nativo.
STT_BASE_URL=https://api.openai.com/v1
STT_API_KEY=your-stt-api-key
STT_MODEL=whisper-1

# Obligatoria para interpretacion de habitos con Gemini.
GEMINI_API_KEY=your_gemini_api_key

# Opcional: modelo utilizado por Gemini.
GEMINI_MODEL=gemini-3.1-flash-lite

# Obligatorias actualmente porque Settings las declara sin valor por defecto.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_this_seed_password
SEED_ADMIN_DOCUMENT_ID=00000000
